# Anthropic API key (required for anthropic/ models — the default)
ANTHROPIC_API_KEY=

# OpenAI API key (required for openai/ models)
OPENAI_API_KEY=

# OpenRouter API key (required for openrouter/ models)
OPENROUTER_API_KEY=

# Google Gemini API key (required for gemini/ models — Google AI Studio)
GEMINI_API_KEY=

# Groq API key (required for groq/ models — fast inference)
GROQ_API_KEY=

# Local inference (LM Studio, Ollama, vLLM, etc.) — use model prefix "local/", e.g. "local/qwen2.5-coder-32b"
LOCAL_PROVIDER_BASE_URL=http://localhost:1234/v1
# LOCAL_PROVIDER_API_KEY=local

# Custom OpenAI-compatible provider (use model prefix "custom/", e.g. "custom/my-model")
CUSTOM_PROVIDER_BASE_URL=
CUSTOM_PROVIDER_API_KEY=

# Brave Search API key (required for WebSearch tool)
BRAVE_SEARCH_API_KEY=

# Jina Reader API key (optional — higher rate limits for WebFetch jina backend)
JINA_API_KEY=

# Authentication — set AUTH_PASSWORD to enable login gate
# When set, web UI requires password login; API requires Bearer token.
AUTH_PASSWORD=
# Static API key for programmatic access (Authorization: Bearer <key>)
AUTH_API_KEY=
# Instance-specific secret for HMAC signing (auto-generated to data/.auth_secret if not set)
# AUTH_SECRET=

# Set to 1 when running behind a reverse proxy (nginx, Caddy) with TLS.
# Taurus itself runs plain HTTP, but this flag tells it the client-facing connection
# is HTTPS, so session cookies are set with the Secure flag. Without it, browsers
# may reject or warn about cookies served over HTTPS without the Secure attribute.
# TAURUS_HTTPS=1

# Server port (default: 7777)
TAURUS_PORT=7777

# Node environment: "local" (shows error details) or "production" (masks internal errors)
# NODE_ENV=local

# Base path for all Taurus persistent data (DB, sessions, lockfile, auth secret, drives).
# Relative paths are resolved from project root. Default: ./data
# TAURUS_DATA_PATH=./data

# Base path for agent drive storage (bind-mounted as /workspace and /shared in containers).
# Relative paths are resolved from project root. Default: ${TAURUS_DATA_PATH}/taurus-drives
# TAURUS_DRIVE_PATH=./data/taurus-drives

# Allow agents to have arbitrary host bind mounts (the "mounts" field on agents).
# Default: true if NODE_ENV=local, false otherwise. Set explicitly to override.
# Disable in multi-tenant deployments to prevent container escape via bind mounts.
# TAURUS_ALLOW_ARBITRARY_BIND_MOUNTS=false

# ── Multi-tenancy: secret sharing & budget ──

# Which server API keys are shared with non-admin users (comma-separated env var names).
# Default: none — users must provide their own keys (BYOK) unless admin explicitly shares.
# Only applies in production (NODE_ENV != local). Local installs share all keys.
# Include utility keys (BRAVE_SEARCH_API_KEY, JINA_API_KEY) if you want users to
# have web search/fetch without providing their own keys.
# TAURUS_SHARED_SECRETS=ANTHROPIC_API_KEY,OPENAI_API_KEY,BRAVE_SEARCH_API_KEY,JINA_API_KEY

# Default monthly spending budget per user (USD) when using shared server keys.
# Users with their own API keys (BYOK) are not limited. Admin users are exempt.
# Only applies in production (NODE_ENV != local). Set to 0 to disable budget enforcement.
# TAURUS_DEFAULT_MONTHLY_BUDGET=50
